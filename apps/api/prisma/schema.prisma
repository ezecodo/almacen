generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id         Int              @id @default(autoincrement())
  nombre     String
  placeId    String?
  retiros    Retiro[]
  reviews    ReviewSnapshot[]
  propinas   PropinaDia[]
  menu       MenuItem[]
  floorPlans FloorPlan[]
  comandas   Comanda[]
  createdAt  DateTime         @default(now())
}

model ReviewSnapshot {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  total        Int
  rating       Float
  fecha        DateTime   @default(now())
}

model Empleado {
  id        Int            @id @default(autoincrement())
  nombre    String
  tipo      String         @default("cocina")
  pin       String?        @unique
  telefono  String?
  retiros   Retiro[]
  turnos    PropinaTurno[]
  activo    Boolean        @default(true)
  createdAt DateTime       @default(now())
}

model PropinaDia {
  id           Int            @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id])
  fecha        DateTime
  efectivo     Float          @default(0)
  tarjeta      Float          @default(0)
  total        Float
  turnos       PropinaTurno[]
  createdAt    DateTime       @default(now())
}

model PropinaTurno {
  id           Int        @id @default(autoincrement())
  propinaDiaId Int
  propinaDia   PropinaDia @relation(fields: [propinaDiaId], references: [id])
  empleadoId   Int
  empleado     Empleado   @relation(fields: [empleadoId], references: [id])
  horas        Float      @default(8)
  propina      Float
}

model Retiro {
  id             Int          @id @default(autoincrement())
  createdAt      DateTime     @default(now())
  empleadoId     Int
  restaurantId   Int
  empleado       Empleado     @relation(fields: [empleadoId], references: [id])
  restaurant     Restaurant   @relation(fields: [restaurantId], references: [id])
  items          RetiroItem[]
  confirmadoAt   DateTime?
  confirmadoPor  String?
}

model RetiroItem {
  id       Int    @id @default(autoincrement())
  retiroId Int
  retiro   Retiro @relation(fields: [retiroId], references: [id])
  barcode  String
  nombre   String
  cantidad Float
  unidad   String
}

model MenuItem {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  categoria    String
  nombre       String
  descripcion  String     @default("")
  precio       Float
  activo       Boolean    @default(true)
  orden        Int        @default(0)
  createdAt    DateTime   @default(now())
}

model FloorPlan {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  nombre       String
  mesas        Mesa[]
  createdAt    DateTime   @default(now())
}

model Mesa {
  id          Int       @id @default(autoincrement())
  floorPlanId Int
  floorPlan   FloorPlan @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)
  numero      Int
  tipo        String    // 'round' | 'square' | 'rectangular'
  x           Float
  y           Float
  capacidad   Int
  rotacion    Int       @default(0) // 0 | 90 | 180 | 270
  comandas    Comanda[]
  createdAt   DateTime  @default(now())
}

model Comanda {
  id           Int           @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id])
  mesaId       Int
  mesa         Mesa          @relation(fields: [mesaId], references: [id])
  pax            Int
  estado         String        @default("abierta") // 'abierta' | 'enviada' | 'facturada' | 'cerrada'
  metodoPago     String?       // 'cash' | 'tarjeta' | null
  camareroNombre String?
  items        ComandaItem[]
  createdAt    DateTime      @default(now())
  closedAt     DateTime?
}

model ComandaItem {
  id         Int     @id @default(autoincrement())
  comandaId  Int
  comanda    Comanda @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  nombre     String
  precio     Float
  cantidad   Int     @default(1)
  nota       String  @default("")
  nivel      Int?
}

model Producto {
  id        Int      @id @default(autoincrement())
  barcode   String   @unique
  nombre    String
  unidad    String   @default("ud")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
