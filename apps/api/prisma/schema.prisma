generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id                     Int                   @id @default(autoincrement())
  nombre                 String
  placeId                String?
  reviewObjetivoTasa     Int?
  retiros                Retiro[]
  reviews                ReviewSnapshot[]
  propinas               PropinaDia[]
  menu                   MenuItem[]
  menuCats               MenuCategoria[]
  floorPlans             FloorPlan[]
  comandas               Comanda[]
  mermas                 Merma[]
  grupoMenus             GrupoMenuTemplate[]
  grupoAgendados         GrupoAgendado[]
  empleados              Empleado[]
  turnos                 Turno[]
  invCategorias          InventarioCategoria[]
  invProductos           InventarioProducto[]
  invConteos             InventarioConteo[]
  invProducciones        InventarioProduccion[]
  reservaConfig          ReservaConfig?
  reservas               Reserva[]
  turnosEmpleados        TurnoEmpleado[]
  turnoTipos             TurnoTipo[]
  staffingConfig         StaffingConfig?
  necesidadesDia         StaffingNecesidadDia[]
  necesidadesFecha       StaffingNecesidadFecha[]
  wikiArticulos          WikiArticulo[]
  checklistSectores      ChecklistSector[]
  checklistEjecuciones   ChecklistEjecucion[]
  createdAt              DateTime              @default(now())
}

// ── Wiki ──────────────────────────────────────────────────────────────────────
// Base de conocimiento por restaurante: speeches, protocolos, conceptos.
// Categorías globales (compartidas por la cadena) + artículos con scope
// global (restaurantId = null) o específico de un restaurante.

model WikiCategoria {
  id        Int            @id @default(autoincrement())
  nombre    String
  icono     String         @default("")
  orden     Int            @default(0)
  articulos WikiArticulo[]
  createdAt DateTime       @default(now())
}

model WikiArticulo {
  id           Int           @id @default(autoincrement())
  categoriaId  Int
  categoria    WikiCategoria @relation(fields: [categoriaId], references: [id])
  restaurantId Int?          // null = global (toda la cadena)
  restaurant   Restaurant?   @relation(fields: [restaurantId], references: [id])
  titulo       String
  guiones      Json          @default("{}") // { en?, fr?, de? } — guiones por idioma (lo que lee el TTS)
  notas        String        @default("") // notas/contexto en español para el camarero
  orden        Int           @default(0)
  activo       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// ── Checklists ──────────────────────────────────────────────────────────────────
// Cada restaurante define sus sectores (Barra 1, Sala 2, Paso…). Cada sector tiene
// ítems de apertura y de cierre. Cada vez que el personal completa uno se registra
// una ejecución con snapshot inmutable de lo marcado (accountability).

model ChecklistSector {
  id           Int                  @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant           @relation(fields: [restaurantId], references: [id])
  nombre       String               // "Barra 1", "Sala 2", "Paso"
  orden        Int                  @default(0)
  items        ChecklistItem[]
  ejecuciones  ChecklistEjecucion[]
  createdAt    DateTime             @default(now())
}

model ChecklistItem {
  id        Int             @id @default(autoincrement())
  sectorId  Int
  sector    ChecklistSector @relation(fields: [sectorId], references: [id])
  momento   String          // 'apertura' | 'cierre'
  texto     String
  orden     Int             @default(0)
  createdAt DateTime        @default(now())
}

model ChecklistEjecucion {
  id            Int             @id @default(autoincrement())
  sectorId      Int
  sector        ChecklistSector @relation(fields: [sectorId], references: [id])
  restaurantId  Int
  restaurant    Restaurant      @relation(fields: [restaurantId], references: [id])
  momento       String          // 'apertura' | 'cierre'
  completadoPor String
  itemsMarcados Json            // snapshot: [{ texto: string, marcado: boolean }]
  fecha         DateTime        @default(now())
}

model Turno {
  id              Int        @id @default(autoincrement())
  restaurantId    Int
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id])
  estado          String     @default("abierto") // 'abierto' | 'cerrado'
  encargadoNombre String?
  aperturaAt      DateTime   @default(now())
  cierreAt        DateTime?
  // Totales calculados al cerrar
  totalEfectivo   Float?
  totalTarjeta    Float?
  totalVentas     Float?
  totalMermas     Float?
  totalPropinas   Float?
  totalInvitaciones Float?  // valor de items marcados como invitación de la casa (no suman a ventas)
  numComandas     Int?
  propina         PropinaDia?
  createdAt       DateTime   @default(now())
}

model Merma {
  id             Int        @id @default(autoincrement())
  restaurantId   Int
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id])
  mesaNumero     Int?
  planNombre     String?
  comandaId      Int?
  comanda        Comanda?   @relation(fields: [comandaId], references: [id])
  itemNombre     String
  cantidad       Int        @default(1)
  precio         Float      @default(0)
  itemNivel      Int?
  itemRonda      Int        @default(1)
  camareroNombre String?
  motivo         String     // 'no_servido' | 'queja_cliente' | 'otro'
  descripcion    String?
  createdAt      DateTime   @default(now())
}

model ReviewSnapshot {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  total        Int
  rating       Float
  fecha        DateTime   @default(now())
}

model Empleado {
  id               Int              @id @default(autoincrement())
  nombre           String
  tipo             String           @default("cocina")
  pin              String?          @unique
  telefono         String?
  email            String?
  rol              String?          // cocina: 'friegaplatos'|'cocinero'|'produccion' / sala: 'camarero'|'encargado'
  puedeEncargado   Boolean          @default(false) // camarero que puede cubrir turno de encargado (concepto de planning)
  accesoEncargadoApp Boolean        @default(false) // superpoder: desbloquea el modo encargado 💼 en la app de sala (independiente del planning)
  puedeJefeCocina  Boolean          @default(false) // cocinero que puede cubrir turno de jefe de cocina
  excluirPlanning  Boolean          @default(false) // no incluir en auto-planning
  restaurantId     Int?             // restaurante habitual (null = rotativo)
  restaurant       Restaurant?      @relation(fields: [restaurantId], references: [id])
  retiros          Retiro[]
  turnos           PropinaTurno[]
  activo           Boolean          @default(true)
  horasSemanales      Int              @default(40)
  diasLibresFijos     Int[]            @default([]) // días fijos de libranza: 0=Lun … 6=Dom
  faseLibreRotacion   Int              @default(0)  // 0-3: fase actual en rotación de días libres
  turnosAsignados     TurnoEmpleado[]
  createdAt        DateTime         @default(now())
}

model PropinaDia {
  id           Int            @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id])
  turnoId      Int?           @unique
  turno        Turno?         @relation(fields: [turnoId], references: [id])
  fecha        DateTime
  efectivo     Float          @default(0)
  tarjeta      Float          @default(0)
  total        Float
  turnos       PropinaTurno[]
  createdAt    DateTime       @default(now())
}

model PropinaTurno {
  id           Int        @id @default(autoincrement())
  propinaDiaId Int
  propinaDia   PropinaDia @relation(fields: [propinaDiaId], references: [id])
  empleadoId   Int
  empleado     Empleado   @relation(fields: [empleadoId], references: [id])
  horas        Float      @default(8)
  propina      Float
}

model Retiro {
  id             Int          @id @default(autoincrement())
  createdAt      DateTime     @default(now())
  empleadoId     Int?         // null si el empleado fue eliminado
  empleadoNombre String?      // nombre guardado al crear (persiste aunque se elimine el empleado)
  restaurantId   Int
  empleado       Empleado?    @relation(fields: [empleadoId], references: [id])
  restaurant     Restaurant   @relation(fields: [restaurantId], references: [id])
  items          RetiroItem[]
  confirmadoAt   DateTime?
  confirmadoPor  String?
}

model RetiroItem {
  id       Int    @id @default(autoincrement())
  retiroId Int
  retiro   Retiro @relation(fields: [retiroId], references: [id])
  barcode  String
  nombre   String
  cantidad Float
  unidad   String
}

model MenuCategoria {
  id           Int         @id @default(autoincrement())
  restaurantId Int?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  grupo        String     @default("")
  nombre       String
  icono        String     @default("")
  orden        Int        @default(0)
  ordenAlfabetico Boolean @default(false) // mostrar los items A→Z en vez del orden manual (carta física)
  parentId     Int?       // subcategoría: id de la categoría contenedora (1 solo nivel)
  parent       MenuCategoria?  @relation("SubCategorias", fields: [parentId], references: [id])
  children     MenuCategoria[] @relation("SubCategorias")
  createdAt    DateTime   @default(now())
}

model MenuItem {
  id           Int         @id @default(autoincrement())
  restaurantId Int?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  categoria    String
  nombre       String
  descripcion  String     @default("")
  precio       Float
  activo       Boolean    @default(true)
  autoPorPax   Boolean    @default(false)
  ocultoEnCarta Boolean   @default(false) // no se muestra en el picker del camarero (sigue activo: se cobra y se auto-añade)
  orden        Int        @default(0)
  alergenos    Int        @default(0)
  // Combinados: destilado marcado combinable + pool global de mixers
  combinable      Boolean @default(false)  // se puede pedir combinado (destilados)
  precioCombinado Float?                   // precio del combinado, refresco incluido (null = usar precio)
  esMixer         Boolean @default(false)  // sirve de mezcla (refrescos, tónicas…)
  suplementoMixer Float   @default(0)      // extra si el mixer es premium (Red Bull +1.50)
  createdAt    DateTime   @default(now())
}

model FloorPlan {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  nombre       String
  mesas        Mesa[]
  createdAt    DateTime   @default(now())
}

model Mesa {
  id          Int       @id @default(autoincrement())
  floorPlanId Int
  floorPlan   FloorPlan @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)
  numero      Int
  tipo        String    // 'round' | 'square' | 'rectangular' | 'barra' | 'silla_alta'
  x           Float
  y           Float
  capacidad   Int
  rotacion    Int       @default(0) // 0 | 90 | 180 | 270
  ancho       Int?      // ancho px personalizado (barra)
  alto        Int?      // alto px personalizado (barra)
  comandas    Comanda[]
  createdAt   DateTime  @default(now())
}

model Comanda {
  id           Int           @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id])
  mesaId       Int?
  mesa         Mesa?         @relation(fields: [mesaId], references: [id])
  pax            Int
  estado         String        @default("abierta") // 'abierta' | 'enviada' | 'facturada' | 'liberada' | 'cerrada'
  metodoPago     String?       // 'cash' | 'tarjeta' | null
  propina        Float         @default(0)
  camareroNombre String?
  cuentaDesactualizada Boolean @default(false) // los items cambiaron tras imprimir la cuenta → reimprimir antes de cobrar
  enviadaAt      DateTime?     // primera vez que la comanda se envió a cocina ("hora de comandada")
  items        ComandaItem[]
  mermas       Merma[]
  createdAt    DateTime      @default(now())
  closedAt     DateTime?
}

model ComandaItem {
  id         Int     @id @default(autoincrement())
  comandaId  Int
  comanda    Comanda @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  nombre     String
  precio     Float
  cantidad   Int     @default(1)
  nota       String  @default("")
  nivel      Int?
  ronda      Int     @default(0) // 0=pendiente, 1=comanda original, 2+=marcha pasa
  tipo         String  @default("cocina") // 'cocina' | 'barra'
  autoGenerado Boolean @default(false)   // true = auto-añadido al abrir mesa (no va a cocina/barra)
  invitacion   Boolean @default(false)   // 🎁 invitación de la casa: visible en cuenta a 0 €, no suma a ventas
  invitadoPor  String?                   // quién la marcó
  invitacionMotivo String?               // por qué se invitó (opcional) (accountability)
}

model Producto {
  id        Int      @id @default(autoincrement())
  barcode   String   @unique
  nombre    String
  unidad    String   @default("ud")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventarioCategoria {
  id             Int                  @id @default(autoincrement())
  nombre              String
  orden               Int                  @default(0)
  personalProduccion  String?              // null = no es producción | 'sala' | 'cocina'
  restaurantId        Int?
  restaurant     Restaurant?          @relation(fields: [restaurantId], references: [id])
  productos      InventarioProducto[]
}

model InventarioProducto {
  id             Int                    @id @default(autoincrement())
  nombre         String
  unidad         String                 @default("ud")
  stockMinimo    Float                  @default(0)
  precioCoste    Float?
  precioVenta    Float?
  orden          Int                    @default(0)
  activo         Boolean                @default(true)
  categoriaId    Int
  categoria    InventarioCategoria    @relation(fields: [categoriaId], references: [id])
  restaurantId Int?
  restaurant   Restaurant?            @relation(fields: [restaurantId], references: [id])
  items        InventarioConteoItem[]
  producciones InventarioProduccion[]
}

model InventarioConteo {
  id           Int                    @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant             @relation(fields: [restaurantId], references: [id])
  fecha        DateTime               @default(now())
  creadoPor    String?
  notas        String?
  cerrado      Boolean                @default(false)
  items        InventarioConteoItem[]
  createdAt    DateTime               @default(now())
}

model InventarioProduccion {
  id           Int                @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant         @relation(fields: [restaurantId], references: [id])
  productoId   Int
  producto     InventarioProducto @relation(fields: [productoId], references: [id])
  cantidad     Float
  unidad       String
  creadoPor    String?
  notas        String?
  fecha        DateTime           @default(now())
  createdAt    DateTime           @default(now())
}

model InventarioConteoItem {
  id         Int                @id @default(autoincrement())
  conteoId   Int
  conteo     InventarioConteo   @relation(fields: [conteoId], references: [id], onDelete: Cascade)
  productoId Int
  producto   InventarioProducto @relation(fields: [productoId], references: [id])
  cantidad   Float

  @@unique([conteoId, productoId])
}

model ReservaConfig {
  id             Int              @id @default(autoincrement())
  restaurantId   Int              @unique
  restaurant     Restaurant       @relation(fields: [restaurantId], references: [id])
  slug           String           @unique
  activo         Boolean          @default(true)
  maxPaxPorSlot  Int              @default(20)
  duracionMin    Int              @default(90)
  diasAntelacion Int              @default(30)
  horarios       ReservaHorario[]
  reservas       Reserva[]
  createdAt      DateTime         @default(now())
}

model ReservaHorario {
  id           Int           @id @default(autoincrement())
  configId     Int
  config       ReservaConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  nombre       String        @default("Noche")
  diasSemana   Json
  horaInicio   String
  horaFin      String
  intervaloMin Int           @default(15)
  maxPax       Int           @default(20)
  activo       Boolean       @default(true)
}

model Reserva {
  id           Int           @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id])
  configId     Int
  config       ReservaConfig @relation(fields: [configId], references: [id])
  fecha        DateTime
  hora         String
  pax          Int
  nombre       String
  telefono     String
  email        String?
  notas        String?
  estado       String        @default("confirmada")
  origen       String        @default("web")
  createdAt    DateTime      @default(now())
}

// Plantillas de menú cerrado para grupos
// niveles: GrupoMenuNivel[] almacenado como JSON
// GrupoMenuNivel = { nivel: number, plato: string, vegetariano?: string, sinCerdo?: string, sinGluten?: string, esPostre?: boolean }
model GrupoMenuTemplate {
  id             Int              @id @default(autoincrement())
  restaurantId   Int
  restaurant     Restaurant       @relation(fields: [restaurantId], references: [id])
  nombre         String           // "Estándar" | "Premium" | "Deluxe"
  precio         Float            // precio por persona
  paxPorRacion   Int              @default(3) // tapeo compartido: 1 ración de cada plato cada X pax (sugerencia de cantidades)
  niveles        Json             // GrupoMenuNivel[]
  activo         Boolean          @default(true)
  agendados      GrupoAgendado[]
  createdAt      DateTime         @default(now())
}

// Grupo programado para una fecha concreta
// restricciones: { normales, vegetarianos, sinCerdo, sinGluten }
model GrupoAgendado {
  id            Int               @id @default(autoincrement())
  restaurantId  Int
  restaurant    Restaurant        @relation(fields: [restaurantId], references: [id])
  templateId    Int
  template      GrupoMenuTemplate @relation(fields: [templateId], references: [id])
  fecha         DateTime          // fecha del evento (solo se usa la parte de fecha)
  pax           Int
  restricciones Json              // GrupoMenuRestricciones
  notas         String?
  estado        String            @default("pendiente") // 'pendiente' | 'asignado' | 'cancelado'
  comandaId     Int?              @unique
  createdAt     DateTime          @default(now())
}

model TurnoTipo {
  id                   Int             @id @default(autoincrement())
  restaurantId         Int?            // null = global (compartido entre todos los restaurantes)
  restaurant           Restaurant?     @relation(fields: [restaurantId], references: [id])
  nombre               String
  horaInicio           String
  horaFin              String
  horas                Float
  color                String          @default("#6366f1")
  tipoEmpleado         String?         // 'cocina' | 'sala' | null (= ambos)
  rolEmpleado          String?         // rol específico: 'jefe_cocina' | 'cocinero' | etc. | null (= todos los roles)
  excluirAutoPlanning  Boolean         @default(false)
  activo               Boolean         @default(true)
  turnos               TurnoEmpleado[]
  createdAt            DateTime        @default(now())
}

model TurnoEmpleado {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  empleadoId   Int
  empleado     Empleado   @relation(fields: [empleadoId], references: [id])
  tipoId       Int?
  tipo         TurnoTipo? @relation(fields: [tipoId], references: [id])
  fecha        DateTime
  horaInicio   String
  horaFin      String
  estado       String     @default("planificado") // 'planificado' | 'confirmado' | 'ausente'
  esExtra      Boolean    @default(false)
  createdAt    DateTime   @default(now())

  @@index([restaurantId, fecha])
}

model StaffingConfig {
  id              Int        @id @default(autoincrement())
  restaurantId    Int        @unique
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id])
  ratioSalaXPax   Int        @default(20)
  ratioCocinaXPax Int        @default(30)
  createdAt       DateTime   @default(now())
}

// Plantilla base: personal estándar por día de la semana
model StaffingNecesidadDia {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  diaSemana    Int        // 0=Lun 1=Mar 2=Mié 3=Jue 4=Vie 5=Sáb 6=Dom
  jefeCocina   Int        @default(0)
  cocineros    Int        @default(0)
  friegaplatos Int        @default(0)
  produccion   Int        @default(0)
  camareros    Int        @default(0)
  encargados   Int        @default(0)

  @@unique([restaurantId, diaSemana])
}

// Extras por fecha concreta (festivos, eventos, viernes especiales…)
model StaffingNecesidadFecha {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  fecha        DateTime   // fecha exacta (UTC 00:00)
  jefeCocina   Int        @default(0)
  cocineros    Int        @default(0)
  friegaplatos Int        @default(0)
  produccion   Int        @default(0)
  camareros    Int        @default(0)
  encargados   Int        @default(0)
  notas        String?

  @@unique([restaurantId, fecha])
}
