generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id        Int             @id @default(autoincrement())
  nombre    String
  placeId   String?
  retiros   Retiro[]
  reviews   ReviewSnapshot[]
  propinas  PropinaDia[]
  menu      MenuItem[]
  createdAt DateTime        @default(now())
}

model ReviewSnapshot {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  total        Int
  rating       Float
  fecha        DateTime   @default(now())
}

model Empleado {
  id        Int            @id @default(autoincrement())
  nombre    String
  tipo      String         @default("cocina")
  pin       String?        @unique
  telefono  String?
  retiros   Retiro[]
  turnos    PropinaTurno[]
  activo    Boolean        @default(true)
  createdAt DateTime       @default(now())
}

model PropinaDia {
  id           Int            @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id])
  fecha        DateTime
  efectivo     Float          @default(0)
  tarjeta      Float          @default(0)
  total        Float
  turnos       PropinaTurno[]
  createdAt    DateTime       @default(now())
}

model PropinaTurno {
  id           Int        @id @default(autoincrement())
  propinaDiaId Int
  propinaDia   PropinaDia @relation(fields: [propinaDiaId], references: [id])
  empleadoId   Int
  empleado     Empleado   @relation(fields: [empleadoId], references: [id])
  horas        Float      @default(8)
  propina      Float
}

model Retiro {
  id             Int          @id @default(autoincrement())
  createdAt      DateTime     @default(now())
  empleadoId     Int
  restaurantId   Int
  empleado       Empleado     @relation(fields: [empleadoId], references: [id])
  restaurant     Restaurant   @relation(fields: [restaurantId], references: [id])
  items          RetiroItem[]
  confirmadoAt   DateTime?
  confirmadoPor  String?
}

model RetiroItem {
  id       Int    @id @default(autoincrement())
  retiroId Int
  retiro   Retiro @relation(fields: [retiroId], references: [id])
  barcode  String
  nombre   String
  cantidad Float
  unidad   String
}

model MenuItem {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  categoria    String
  nombre       String
  descripcion  String     @default("")
  precio       Float
  activo       Boolean    @default(true)
  orden        Int        @default(0)
  createdAt    DateTime   @default(now())
}

model Producto {
  id        Int      @id @default(autoincrement())
  barcode   String   @unique
  nombre    String
  unidad    String   @default("ud")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
