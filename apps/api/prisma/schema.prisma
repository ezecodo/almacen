generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id                     Int                   @id @default(autoincrement())
  nombre                 String
  placeId                String?
  reviewObjetivoTasa     Int?
  retiros                Retiro[]
  reviews                ReviewSnapshot[]
  propinas               PropinaDia[]
  menu                   MenuItem[]
  menuCats               MenuCategoria[]
  floorPlans             FloorPlan[]
  comandas               Comanda[]
  mermas                 Merma[]
  grupoMenus             GrupoMenuTemplate[]
  grupoAgendados         GrupoAgendado[]
  empleados              Empleado[]
  turnos                 Turno[]
  invCategorias          InventarioCategoria[]
  invProductos           InventarioProducto[]
  invConteos             InventarioConteo[]
  reservaConfig          ReservaConfig?
  reservas               Reserva[]
  turnosEmpleados        TurnoEmpleado[]
  turnoTipos             TurnoTipo[]
  staffingConfig         StaffingConfig?
  necesidadesDia         StaffingNecesidadDia[]
  necesidadesFecha       StaffingNecesidadFecha[]
  createdAt              DateTime              @default(now())
}

model Turno {
  id              Int        @id @default(autoincrement())
  restaurantId    Int
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id])
  estado          String     @default("abierto") // 'abierto' | 'cerrado'
  encargadoNombre String?
  aperturaAt      DateTime   @default(now())
  cierreAt        DateTime?
  // Totales calculados al cerrar
  totalEfectivo   Float?
  totalTarjeta    Float?
  totalVentas     Float?
  totalMermas     Float?
  totalPropinas   Float?
  numComandas     Int?
  propina         PropinaDia?
  createdAt       DateTime   @default(now())
}

model Merma {
  id             Int        @id @default(autoincrement())
  restaurantId   Int
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id])
  mesaNumero     Int?
  planNombre     String?
  comandaId      Int?
  comanda        Comanda?   @relation(fields: [comandaId], references: [id])
  itemNombre     String
  cantidad       Int        @default(1)
  precio         Float      @default(0)
  itemNivel      Int?
  itemRonda      Int        @default(1)
  camareroNombre String?
  motivo         String     // 'no_servido' | 'queja_cliente' | 'otro'
  descripcion    String?
  createdAt      DateTime   @default(now())
}

model ReviewSnapshot {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  total        Int
  rating       Float
  fecha        DateTime   @default(now())
}

model Empleado {
  id              Int              @id @default(autoincrement())
  nombre          String
  tipo            String           @default("cocina")
  pin             String?          @unique
  telefono        String?
  email           String?
  rol             String?          // cocina: 'friegaplatos'|'cocinero'|'produccion' / sala: 'camarero'|'encargado'
  restaurantId    Int?             // restaurante habitual (null = rotativo)
  restaurant      Restaurant?      @relation(fields: [restaurantId], references: [id])
  retiros         Retiro[]
  turnos          PropinaTurno[]
  activo          Boolean          @default(true)
  horasSemanales  Int              @default(40)
  turnosAsignados TurnoEmpleado[]
  createdAt       DateTime         @default(now())
}

model PropinaDia {
  id           Int            @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id])
  turnoId      Int?           @unique
  turno        Turno?         @relation(fields: [turnoId], references: [id])
  fecha        DateTime
  efectivo     Float          @default(0)
  tarjeta      Float          @default(0)
  total        Float
  turnos       PropinaTurno[]
  createdAt    DateTime       @default(now())
}

model PropinaTurno {
  id           Int        @id @default(autoincrement())
  propinaDiaId Int
  propinaDia   PropinaDia @relation(fields: [propinaDiaId], references: [id])
  empleadoId   Int
  empleado     Empleado   @relation(fields: [empleadoId], references: [id])
  horas        Float      @default(8)
  propina      Float
}

model Retiro {
  id             Int          @id @default(autoincrement())
  createdAt      DateTime     @default(now())
  empleadoId     Int
  restaurantId   Int
  empleado       Empleado     @relation(fields: [empleadoId], references: [id])
  restaurant     Restaurant   @relation(fields: [restaurantId], references: [id])
  items          RetiroItem[]
  confirmadoAt   DateTime?
  confirmadoPor  String?
}

model RetiroItem {
  id       Int    @id @default(autoincrement())
  retiroId Int
  retiro   Retiro @relation(fields: [retiroId], references: [id])
  barcode  String
  nombre   String
  cantidad Float
  unidad   String
}

model MenuCategoria {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  grupo        String     @default("")
  nombre       String
  icono        String     @default("")
  orden        Int        @default(0)
  createdAt    DateTime   @default(now())
}

model MenuItem {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  categoria    String
  nombre       String
  descripcion  String     @default("")
  precio       Float
  activo       Boolean    @default(true)
  autoPorPax   Boolean    @default(false)
  orden        Int        @default(0)
  alergenos    Int        @default(0)
  createdAt    DateTime   @default(now())
}

model FloorPlan {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  nombre       String
  mesas        Mesa[]
  createdAt    DateTime   @default(now())
}

model Mesa {
  id          Int       @id @default(autoincrement())
  floorPlanId Int
  floorPlan   FloorPlan @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)
  numero      Int
  tipo        String    // 'round' | 'square' | 'rectangular' | 'barra' | 'silla_alta'
  x           Float
  y           Float
  capacidad   Int
  rotacion    Int       @default(0) // 0 | 90 | 180 | 270
  ancho       Int?      // ancho px personalizado (barra)
  alto        Int?      // alto px personalizado (barra)
  comandas    Comanda[]
  createdAt   DateTime  @default(now())
}

model Comanda {
  id           Int           @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id])
  mesaId       Int?
  mesa         Mesa?         @relation(fields: [mesaId], references: [id])
  pax            Int
  estado         String        @default("abierta") // 'abierta' | 'enviada' | 'facturada' | 'liberada' | 'cerrada'
  metodoPago     String?       // 'cash' | 'tarjeta' | null
  propina        Float         @default(0)
  camareroNombre String?
  items        ComandaItem[]
  mermas       Merma[]
  createdAt    DateTime      @default(now())
  closedAt     DateTime?
}

model ComandaItem {
  id         Int     @id @default(autoincrement())
  comandaId  Int
  comanda    Comanda @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  nombre     String
  precio     Float
  cantidad   Int     @default(1)
  nota       String  @default("")
  nivel      Int?
  ronda      Int     @default(0) // 0=pendiente, 1=comanda original, 2+=marcha pasa
  tipo         String  @default("cocina") // 'cocina' | 'barra'
  autoGenerado Boolean @default(false)   // true = auto-añadido al abrir mesa (no va a cocina/barra)
}

model Producto {
  id        Int      @id @default(autoincrement())
  barcode   String   @unique
  nombre    String
  unidad    String   @default("ud")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventarioCategoria {
  id           Int                  @id @default(autoincrement())
  nombre       String
  orden        Int                  @default(0)
  restaurantId Int?
  restaurant   Restaurant?          @relation(fields: [restaurantId], references: [id])
  productos    InventarioProducto[]
}

model InventarioProducto {
  id           Int                    @id @default(autoincrement())
  nombre       String
  unidad       String                 @default("ud")
  stockMinimo  Float                  @default(0)
  orden        Int                    @default(0)
  activo       Boolean                @default(true)
  categoriaId  Int
  categoria    InventarioCategoria    @relation(fields: [categoriaId], references: [id])
  restaurantId Int?
  restaurant   Restaurant?            @relation(fields: [restaurantId], references: [id])
  items        InventarioConteoItem[]
}

model InventarioConteo {
  id           Int                    @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant             @relation(fields: [restaurantId], references: [id])
  fecha        DateTime               @default(now())
  creadoPor    String?
  notas        String?
  cerrado      Boolean                @default(false)
  items        InventarioConteoItem[]
  createdAt    DateTime               @default(now())
}

model InventarioConteoItem {
  id         Int                @id @default(autoincrement())
  conteoId   Int
  conteo     InventarioConteo   @relation(fields: [conteoId], references: [id], onDelete: Cascade)
  productoId Int
  producto   InventarioProducto @relation(fields: [productoId], references: [id])
  cantidad   Float

  @@unique([conteoId, productoId])
}

model ReservaConfig {
  id             Int              @id @default(autoincrement())
  restaurantId   Int              @unique
  restaurant     Restaurant       @relation(fields: [restaurantId], references: [id])
  slug           String           @unique
  activo         Boolean          @default(true)
  maxPaxPorSlot  Int              @default(20)
  duracionMin    Int              @default(90)
  diasAntelacion Int              @default(30)
  horarios       ReservaHorario[]
  reservas       Reserva[]
  createdAt      DateTime         @default(now())
}

model ReservaHorario {
  id           Int           @id @default(autoincrement())
  configId     Int
  config       ReservaConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  nombre       String        @default("Noche")
  diasSemana   Json
  horaInicio   String
  horaFin      String
  intervaloMin Int           @default(15)
  maxPax       Int           @default(20)
  activo       Boolean       @default(true)
}

model Reserva {
  id           Int           @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id])
  configId     Int
  config       ReservaConfig @relation(fields: [configId], references: [id])
  fecha        DateTime
  hora         String
  pax          Int
  nombre       String
  telefono     String
  email        String?
  notas        String?
  estado       String        @default("confirmada")
  origen       String        @default("web")
  createdAt    DateTime      @default(now())
}

// Plantillas de menú cerrado para grupos
// niveles: GrupoMenuNivel[] almacenado como JSON
// GrupoMenuNivel = { nivel: number, plato: string, vegetariano?: string, sinCerdo?: string, sinGluten?: string, esPostre?: boolean }
model GrupoMenuTemplate {
  id             Int              @id @default(autoincrement())
  restaurantId   Int
  restaurant     Restaurant       @relation(fields: [restaurantId], references: [id])
  nombre         String           // "Estándar" | "Premium" | "Deluxe"
  precio         Float            // precio por persona
  niveles        Json             // GrupoMenuNivel[]
  activo         Boolean          @default(true)
  agendados      GrupoAgendado[]
  createdAt      DateTime         @default(now())
}

// Grupo programado para una fecha concreta
// restricciones: { normales, vegetarianos, sinCerdo, sinGluten }
model GrupoAgendado {
  id            Int               @id @default(autoincrement())
  restaurantId  Int
  restaurant    Restaurant        @relation(fields: [restaurantId], references: [id])
  templateId    Int
  template      GrupoMenuTemplate @relation(fields: [templateId], references: [id])
  fecha         DateTime          // fecha del evento (solo se usa la parte de fecha)
  pax           Int
  restricciones Json              // GrupoMenuRestricciones
  notas         String?
  estado        String            @default("pendiente") // 'pendiente' | 'asignado' | 'cancelado'
  comandaId     Int?              @unique
  createdAt     DateTime          @default(now())
}

model TurnoTipo {
  id           Int             @id @default(autoincrement())
  restaurantId Int?            // null = global (compartido entre todos los restaurantes)
  restaurant   Restaurant?     @relation(fields: [restaurantId], references: [id])
  nombre       String
  horaInicio   String
  horaFin      String
  horas        Float
  color        String          @default("#6366f1")
  tipoEmpleado String?         // 'cocina' | 'sala' | null (= ambos)
  activo       Boolean         @default(true)
  turnos       TurnoEmpleado[]
  createdAt    DateTime        @default(now())
}

model TurnoEmpleado {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  empleadoId   Int
  empleado     Empleado   @relation(fields: [empleadoId], references: [id])
  tipoId       Int?
  tipo         TurnoTipo? @relation(fields: [tipoId], references: [id])
  fecha        DateTime
  horaInicio   String
  horaFin      String
  estado       String     @default("planificado") // 'planificado' | 'confirmado' | 'ausente'
  createdAt    DateTime   @default(now())

  @@index([restaurantId, fecha])
}

model StaffingConfig {
  id              Int        @id @default(autoincrement())
  restaurantId    Int        @unique
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id])
  ratioSalaXPax   Int        @default(20)
  ratioCocinaXPax Int        @default(30)
  createdAt       DateTime   @default(now())
}

// Plantilla base: personal estándar por día de la semana
model StaffingNecesidadDia {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  diaSemana    Int        // 0=Lun 1=Mar 2=Mié 3=Jue 4=Vie 5=Sáb 6=Dom
  jefeCocina   Int        @default(0)
  cocineros    Int        @default(0)
  friegaplatos Int        @default(0)
  produccion   Int        @default(0)
  camareros    Int        @default(0)
  encargados   Int        @default(0)

  @@unique([restaurantId, diaSemana])
}

// Extras por fecha concreta (festivos, eventos, viernes especiales…)
model StaffingNecesidadFecha {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  fecha        DateTime   // fecha exacta (UTC 00:00)
  jefeCocina   Int        @default(0)
  cocineros    Int        @default(0)
  friegaplatos Int        @default(0)
  produccion   Int        @default(0)
  camareros    Int        @default(0)
  encargados   Int        @default(0)
  notas        String?

  @@unique([restaurantId, fecha])
}
